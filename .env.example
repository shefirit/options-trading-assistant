# Copy this file to ".env" and fill in your own values.
# The .env file is ignored by git and never leaves your PC.

# From your app at https://developer.schwab.com (Phase 0 setup):
SCHWAB_APP_KEY=your_app_key_here
SCHWAB_APP_SECRET=your_app_secret_here

# The callback URL you set on the Schwab developer portal.
# Keep this exactly matching what you entered there.
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182

# Where the login token gets saved after the one-time browser login.
SCHWAB_TOKEN_PATH=token.json
