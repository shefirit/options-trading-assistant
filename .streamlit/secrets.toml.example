# Example of the secrets the HOSTED app uses.
#
# You do NOT edit this file for the cloud. Instead, in the Streamlit Cloud
# dashboard: your app -> Settings -> Secrets -> paste the line below (with your
# real link) -> Save.
#
# For LOCAL runs you don't need this at all - the sidebar "Connect Google Sheet"
# box saves your link to google_sheet_webhook.txt on your PC.

google_sheet_webhook = "https://script.google.com/macros/s/XXXXXXXX/exec"
